# Typical gitignore for a static website
# OS generated files
.DS_Store
Thumbs.db

# IDE / editor folders
.vscode/
.idea/

# Node / npm artifacts (if any)
node_modules/

# Build artifacts
dist/
.build/

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.local

# Misc
*.log
